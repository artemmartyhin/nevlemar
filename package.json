{
  "name": "nevlemar",
  "version": "1.0.0",
  "private": true,
  "repository": "git@github.com:artemmartyhin/nevlemar.git",
  "author": "Artem Martiukhin <artemmartyhin@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/backend",
    "packages/frontend-next"
  ],
  "scripts": {
    "mongo:up": "docker-compose up -d mongodb",
    "mongo:down": "docker-compose down",
    "backend": "npm --workspace packages/backend run start",
    "backend:dev": "npm --workspace packages/backend run start:dev",
    "frontend": "npm --workspace packages/frontend-next run dev",
    "dev": "concurrently -n BE,FE -c blue,green \"npm run backend:dev\" \"npm run frontend\"",
    "build": "npm --workspace packages/backend run build && npm --workspace packages/frontend-next run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
